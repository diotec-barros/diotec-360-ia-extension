{
  "name": "diotec-360-ia-extension",
  "displayName": "DIOTEC 360 IA",
  "description": "AI coding assistant with Mixture of Experts architecture. Built by DIOTEC 360.",
  "version": "0.0.1",
  "publisher": "diotec-360",
  "repository": {
    "type": "git",
    "url": "https://github.com/diotec-barros/diotec-360-ia-extension"
  },
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "submenus": [
      {
        "id": "diotec360.submenu",
        "label": "DIOTEC 360 IA"
      }
    ],
    "commands": [
      {
        "command": "diotec360.generate",
        "title": "DIOTEC 360 IA: Generate"
      },
      {
        "command": "diotec360.explain",
        "title": "DIOTEC 360 IA: Explain"
      },
      {
        "command": "diotec360.refactor",
        "title": "DIOTEC 360 IA: Refactor"
      },
      {
        "command": "diotec360.chat",
        "title": "DIOTEC 360 IA: Chat"
      },
      {
        "command": "diotec360.chatClearHistory",
        "title": "DIOTEC 360 IA: Chat — Clear History"
      },
      {
        "command": "diotec360.applyLastSuggestion",
        "title": "DIOTEC 360 IA: Apply Last Suggestion"
      },
      {
        "command": "diotec360.configureApiKey",
        "title": "DIOTEC 360 IA: Configure OpenAI API Key"
      },
      {
        "command": "diotec360.configureAnthropicApiKey",
        "title": "DIOTEC 360 IA: Configure Anthropic API Key"
      },
      {
        "command": "diotec360.openMemory",
        "title": "DIOTEC 360 IA: Open Memory DB"
      },
      {
        "command": "diotec360.configureSovereignIdentity",
        "title": "DIOTEC 360: Configure Sovereign Identity"
      },
      {
        "command": "diotec360.buyCredits",
        "title": "DIOTEC 360: Buy Credits"
      },
      {
        "command": "diotec360.viewBalance",
        "title": "DIOTEC 360: View Credit Balance"
      }
    ],
    "menus": {
      "diotec360.submenu": [
        {
          "command": "diotec360.generate",
          "group": "1_actions"
        },
        {
          "command": "diotec360.explain",
          "group": "1_actions"
        },
        {
          "command": "diotec360.refactor",
          "group": "1_actions"
        },
        {
          "command": "diotec360.chat",
          "group": "1_actions"
        },
        {
          "command": "diotec360.chatClearHistory",
          "group": "1_actions"
        },
        {
          "command": "diotec360.configureApiKey",
          "group": "2_settings"
        },
        {
          "command": "diotec360.configureAnthropicApiKey",
          "group": "2_settings"
        },
        {
          "command": "diotec360.openMemory",
          "group": "3_memory"
        }
      ],
      "editor/context": [
        {
          "command": "diotec360.generate",
          "when": "editorTextFocus",
          "group": "navigation@1"
        },
        {
          "command": "diotec360.explain",
          "when": "editorTextFocus",
          "group": "navigation@2"
        },
        {
          "command": "diotec360.refactor",
          "when": "editorTextFocus",
          "group": "navigation@3"
        },
        {
          "command": "diotec360.chat",
          "when": "editorTextFocus",
          "group": "navigation@4"
        },
        {
          "command": "diotec360.chatClearHistory",
          "when": "editorTextFocus",
          "group": "navigation@5"
        }
      ],
      "editor/title": [
        {
          "command": "diotec360.generate",
          "when": "editorTextFocus",
          "group": "navigation@1"
        },
        {
          "command": "diotec360.explain",
          "when": "editorTextFocus",
          "group": "navigation@2"
        },
        {
          "command": "diotec360.refactor",
          "when": "editorTextFocus",
          "group": "navigation@3"
        },
        {
          "command": "diotec360.chat",
          "when": "editorTextFocus",
          "group": "navigation@4"
        },
        {
          "command": "diotec360.chatClearHistory",
          "when": "editorTextFocus",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "DIOTEC 360 IA",
      "properties": {
        "angoIA.enabled": {
          "type": "boolean",
          "default": true
        },
        "angoIA.moe.enabled": {
          "type": "boolean",
          "default": false
        },
        "angoIA.moe.writer.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai",
            "anthropic"
          ],
          "default": "ollama",
          "description": "LLM provider for the Writer (code generator)"
        },
        "angoIA.moe.writer.model": {
          "type": "string",
          "default": ""
        },
        "angoIA.moe.critic.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai",
            "anthropic"
          ],
          "default": "openai",
          "description": "🏛️ LLM provider for the Critic (code reviewer). Choose 'anthropic' for Claude 3.5 Sonnet (Premium)."
        },
        "angoIA.moe.critic.model": {
          "type": "string",
          "default": "gpt-4o-mini"
        },
        "angoIA.moe.critic.enabledForGenerate": {
          "type": "boolean",
          "default": true
        },
        "angoIA.moe.critic.enabledForRefactor": {
          "type": "boolean",
          "default": true
        },
        "angoIA.moe.critic.minChars": {
          "type": "number",
          "default": 200,
          "minimum": 0
        },
        "angoIA.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai",
            "anthropic"
          ],
          "default": "ollama",
          "description": "Default LLM provider"
        },
        "angoIA.streaming.enabled": {
          "type": "boolean",
          "default": true
        },
        "angoIA.ollama.endpoint": {
          "type": "string",
          "default": "http://localhost:11434"
        },
        "angoIA.ollama.model": {
          "type": "string",
          "default": "llama3"
        },
        "angoIA.openai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI model to use"
        },
        "angoIA.anthropic.model": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "🏛️ Anthropic model to use (Premium: claude-3-5-sonnet-20241022)"
        },
        "angoIA.memory.enabled": {
          "type": "boolean",
          "default": true
        },
        "angoIA.memory.storeRawContext": {
          "type": "boolean",
          "default": false
        },
        "angoIA.diotec360.endpoint": {
          "type": "string",
          "default": "https://diotec-360-diotec-360-ia-judge.hf.space"
        },
        "angoIA.diotec360.publicKeyHex": {
          "type": "string",
          "default": ""
        },
        "angoIA.mining.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable background proof mining when idle"
        },
        "angoIA.mining.idleThresholdSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "description": "Seconds of inactivity before starting mining"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "lint": "echo 'no lint configured'",
    "package": "vsce package",
    "clean": "rmdir /s /q dist 2>nul || echo Clean complete"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^1.4.0",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "sql.js": "^1.10.3"
  }
}